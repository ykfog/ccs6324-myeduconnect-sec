<!DOCTYPE html>
<html>
<head><title>MyEduConnect</title></head>
<body>
    <h1>Welcome to MyEduConnect</h1>
    <% if (user) { %>
        <p>Hello, <%= user.username %> | <a href="/logout">Logout</a></p>
        <p><a href="/courses">Browse Courses</a> | <a href="/profile/<%= user.id %>">My Profile</a></p>
    <% } else { %>
        <p><a href="/login">Login</a> | <a href="/register">Register</a></p>
    <% } %>
</body>
</html>