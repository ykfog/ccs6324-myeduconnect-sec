<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile: <%= profile.username %> — MyEduConnect</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="page-wrapper">

  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-brand" style="text-decoration:none;">My<span>Edu</span>Connect</a>
      <ul class="nav-links">
        <li><a href="/courses">Courses</a></li>
        <li><a href="/">Home</a></li>
      </ul>
    </div>
  </nav>

  <div class="container" style="max-width: 600px; margin-top: 60px;">
    <div class="card animate">
      <h1 class="section-title" style="font-size: 2.2rem; margin-bottom: 24px;">User <em>Profile</em></h1>

      <div style="margin-bottom: 16px;">
        <span class="text-mono text-muted" style="font-size: 11px; letter-spacing: 0.1em;">USERNAME</span>
        <div style="font-size: 1.2rem; color: var(--cream);"><%= profile.username %></div>
      </div>

      <div style="margin-bottom: 16px;">
        <span class="text-mono text-muted" style="font-size: 11px; letter-spacing: 0.1em;">FULL NAME</span>
        <div style="font-size: 1.1rem; color: var(--cream);"><%= profile.fullname %></div>
      </div>

      <div style="margin-bottom: 32px;">
        <span class="text-mono text-muted" style="font-size: 11px; letter-spacing: 0.1em;">BIOGRAPHY</span>
        <div style="background: var(--surface2); padding: 20px; border-radius: var(--radius); margin-top: 8px; border: 1px solid var(--border); color: var(--muted);">
          <%- profile.bio || '<em style="color: var(--border2);">No biography provided.</em>' %>
        </div>
      </div>

      <% if (own) { %>
        <hr class="divider">
        <h3 style="color: var(--cream); font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 16px;">Update Biography</h3>
        <form method="POST" action="/profile/<%= profile.id %>/update">
          <div class="form-group">
            <textarea name="bio" class="form-textarea" placeholder="Tell us about yourself..."><%= profile.bio %></textarea>
          </div>
          <button type="submit" class="btn btn-filled btn-full">Save Changes</button>
        </form>
      <% } %>

    </div>
  </div>
</div>
</body>
</html>
