<!DOCTYPE html>
<html>
<head><title>User Profile - MyEduConnect</title></head>
<body>
    <h2>User Profile</h2>
    <p><strong>Username:</strong> <%= profile.username %></p>
    <p><strong>Full Name:</strong> <%= profile.fullname %></p>
    <p><strong>Bio:</strong> <%- profile.bio %></p>  <!-- Intentionally left unescaped to demonstrate potential XSS vulnerabilities -->

    <% if (own) { %>
        <h3>Update Bio</h3>
        <form method="POST" action="/profile/<%= profile.id %>/update">
            <textarea name="bio" rows="4" cols="50"><%= profile.bio %></textarea><br>
            <button type="submit">Update Bio</button>
        </form>
    <% } %>
    <a href="/">Home</a>
</body>
</html>