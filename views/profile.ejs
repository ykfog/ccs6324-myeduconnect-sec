<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Enrolment — MyEduConnect</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .payment-layout {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 60px 24px;
    }
    .payment-container {
      width: 100%;
      max-width: 880px;
      display: grid;
      grid-template-columns: 1fr 1px 1fr;
      gap: 0;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      overflow: hidden;
    }
    .payment-summary {
      padding: 48px;
      background: var(--surface2);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    .payment-divider-col {
      background: var(--border);
    }
    .payment-form-panel {
      padding: 48px;
    }
    .payment-brand {
      font-family: var(--font-display);
      font-size: 1.3rem;
      color: var(--cream);
      margin-bottom: 40px;
    }
    .payment-brand span { color: var(--gold); }

    .summary-label {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 8px;
    }
    .summary-course-id {
      font-family: var(--font-display);
      font-size: 2rem;
      font-weight: 300;
      color: var(--cream);
      line-height: 1.2;
    }
    .summary-price-wrap {
      margin-top: 40px;
    }
    .summary-price {
      font-family: var(--font-display);
      font-size: 3.5rem;
      font-weight: 300;
      color: var(--gold);
      line-height: 1;
    }
    .summary-price-desc {
      font-size: 12px;
      color: var(--muted);
      font-family: var(--font-mono);
      margin-top: 6px;
    }
    .summary-includes {
      margin-top: 32px;
      list-style: none;
    }
    .summary-includes li {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 0;
      font-size: 13px;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
    }
    .summary-includes li:last-child { border-bottom: none; }
    .summary-includes .check {
      color: var(--success);
      font-size: 12px;
    }
    .security-note {
      margin-top: 24px;
      font-size: 11px;
      color: var(--muted);
      font-family: var(--font-mono);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    /* Form side */
    .payment-form-title {
      font-family: var(--font-display);
      font-size: 1.8rem;
      font-weight: 300;
      color: var(--cream);
      margin-bottom: 6px;
    }
    .payment-form-sub {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 32px;
    }
    .card-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    .demo-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 10px;
      border: 1px solid var(--gold-dim);
      border-radius: 3px;
      font-size: 10px;
      font-family: var(--font-mono);
      letter-spacing: .1em;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 24px;
    }
    .form-input-hint {
      font-size: 11px;
      color: var(--muted);
      font-family: var(--font-mono);
      margin-top: 6px;
    }

    @media (max-width: 768px) {
      .payment-container {
        grid-template-columns: 1fr;
      }
      .payment-divider-col { display: none; }
      .payment-summary, .payment-form-panel { padding: 32px 24px; }
    }
  </style>
</head>
<body>
<div class="page-wrapper">

  <div class="payment-layout">
    <div class="payment-container animate">

      <!-- SUMMARY PANEL -->
      <div class="payment-summary">
        <div>
          <a href="/" class="payment-brand" style="text-decoration:none;">My<span>Edu</span>Connect</a>
        </div>

        <div>
          <div class="summary-label">Enrolling in</div>
          <div class="summary-course-id">Course #<%= courseId %></div>

          <div class="summary-price-wrap">
            <div class="summary-price">$49</div>
            <div class="summary-price-desc">One-time payment · No subscription</div>
          </div>

          <ul class="summary-includes">
            <li><span class="check">✓</span> Lifetime access to all content</li>
            <li><span class="check">✓</span> Certificate of completion</li>
            <li><span class="check">✓</span> All future updates included</li>
            <li><span class="check">✓</span> Community discussion access</li>
          </ul>
        </div>

        <div class="security-note">
          🔒 256-bit SSL encrypted checkout
        </div>
      </div>

      <div class="payment-divider-col"></div>

      <!-- FORM PANEL -->
      <div class="payment-form-panel">
        <h2 class="payment-form-title">Complete <em style="font-style:italic;color:var(--gold);">Enrolment</em></h2>
        <p class="payment-form-sub">Enter your payment details below.</p>

        <div class="demo-badge">⚠ Demo Mode — No real charges</div>

        <form method="POST" action="/payment/enroll">
          <input type="hidden" name="course_id" value="<%= courseId %>">

          <div class="form-group">
            <label class="form-label">Card Number</label>
            <input type="text" name="card_number" class="form-input" placeholder="4111 1111 1111 1111" maxlength="19" required>
            <div class="form-input-hint">Use any demo card number</div>
          </div>

          <div class="card-row">
            <div class="form-group">
              <label class="form-label">Expiry Date</label>
              <input type="text" name="expiry" class="form-input" placeholder="MM / YY" maxlength="7">
            </div>
            <div class="form-group">
              <label class="form-label">CVV</label>
              <input type="text" name="cvv" class="form-input" placeholder="123" maxlength="4" required>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Name on Card</label>
            <input type="text" name="card_name" class="form-input" placeholder="Jane Doe">
          </div>

          <button type="submit" class="btn btn-filled btn-full" style="margin-top:8px;">
            Pay &amp; Enrol Now →
          </button>

          <a href="/courses" class="btn btn-ghost btn-full" style="margin-top:12px;">Cancel</a>
        </form>
      </div>

    </div>
  </div>

</div>
</body>
</html>
