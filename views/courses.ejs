<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Courses — MyEduConnect</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .page-header {
      padding: 64px 0 48px;
      border-bottom: 1px solid var(--border);
      position: relative;
      overflow: hidden;
    }
    .page-header::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 50% 100% at 80% 50%, rgba(201,168,76,0.04) 0%, transparent 60%);
      pointer-events: none;
    }
    .page-header-inner {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 24px;
      flex-wrap: wrap;
    }
    .search-bar {
      display: flex;
      gap: 0;
      max-width: 420px;
      width: 100%;
    }
    .search-bar .form-input {
      border-radius: var(--radius-sm) 0 0 var(--radius-sm);
      border-right: none;
    }
    .search-bar .btn {
      border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
      padding: 12px 20px;
    }

    /* Course Grid */
    .courses-section { padding: 48px 0 80px; }
    .courses-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }
    .course-card {
      background: var(--surface);
      padding: 28px;
      transition: background .2s;
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .course-card:hover {
      background: var(--surface2);
    }
    .course-card-num {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--muted);
      letter-spacing: .12em;
    }
    .course-card-title {
      font-family: var(--font-display);
      font-size: 1.3rem;
      font-weight: 400;
      color: var(--cream);
      line-height: 1.3;
    }
    .course-card:hover .course-card-title {
      color: var(--gold);
    }
    .course-card-desc {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.6;
      flex: 1;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .course-card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 14px;
      border-top: 1px solid var(--border);
    }
    .course-arrow {
      font-size: 18px;
      color: var(--muted);
      transition: color .2s, transform .2s;
    }
    .course-card:hover .course-arrow {
      color: var(--gold);
      transform: translateX(4px);
    }
    .courses-empty {
      padding: 80px 32px;
      text-align: center;
      color: var(--muted);
    }
    .courses-empty .icon {
      font-size: 3rem;
      margin-bottom: 16px;
    }

    /* Toolbar */
    .courses-toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 28px;
      flex-wrap: wrap;
      gap: 12px;
    }
    .results-count {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--muted);
    }

    @media (max-width: 640px) {
      .courses-grid { grid-template-columns: 1fr; }
      .page-header-inner { flex-direction: column; align-items: flex-start; }
      .search-bar { max-width: 100%; }
    }
  </style>
</head>
<body>
<div class="page-wrapper">

  <!-- NAV -->
  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-brand" style="font-family:var(--font-display);font-size:1.4rem;font-weight:600;color:var(--cream);">My<span style="color:var(--gold);">Edu</span>Connect</a>
      <ul class="nav-links">
        <li><a href="/courses" style="color:var(--gold);">Courses</a></li>
        <li><a href="/">Home</a></li>
      </ul>
    </div>
  </nav>

  <!-- PAGE HEADER -->
  <div class="page-header">
    <div class="container">
      <div class="page-header-inner">
        <div>
          <div class="animate" style="font-family:var(--font-mono);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:12px;">Course Catalogue</div>
          <h1 class="section-title animate delay-1">Explore &amp; <em>discover.</em></h1>
          <p class="section-sub animate delay-2">Find your next course from our curated library.</p>
        </div>
        <form method="GET" action="/courses" class="search-bar animate delay-2">
          <input type="text" name="search" class="form-input" placeholder="Search courses…" value="<%= typeof search !== 'undefined' ? search : '' %>">
          <button type="submit" class="btn btn-filled">Search</button>
        </form>
      </div>
    </div>
  </div>

  <!-- COURSES SECTION -->
  <section class="courses-section">
    <div class="container">

      <div class="courses-toolbar animate">
        <span class="results-count">
          <%= courses.length %> course<%= courses.length !== 1 ? 's' : '' %> found
        </span>
        <a href="/" class="btn btn-ghost" style="padding:8px 16px;font-size:11px;">← Back to Home</a>
      </div>

      <% if (courses && courses.length > 0) { %>
        <div class="courses-grid animate delay-1">
          <% courses.forEach((course, i) => { %>
            <a href="/courses/<%= course.id %>" class="course-card" style="text-decoration:none;">
              <div class="course-card-num">
                <%= String(i + 1).padStart(2, '0') %>
              </div>
              <div class="course-card-title"><%= course.title %></div>
              <p class="course-card-desc"><%= course.description %></p>
              <div class="course-card-footer">
                <span class="badge badge-gold">Enrol Now</span>
                <span class="course-arrow">→</span>
              </div>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <div class="courses-empty card animate">
          <div class="icon">🔍</div>
          <p>No courses match your search.</p>
          <a href="/courses" class="btn mt-16">View All Courses</a>
        </div>
      <% } %>

    </div>
  </section>

</div>
</body>
</html>
