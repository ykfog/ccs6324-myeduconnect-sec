<!DOCTYPE html>
<html>
<head><title><%= course.title %> - MyEduConnect</title></head>
<body>
    <h1><%= course.title %></h1>
    <p><%= course.description %></p>

    <h3>Comments</h3>
    <% if (comments && comments.length) { %>
        <% comments.forEach(c => { %>
            <div style="border-bottom:1px solid #ccc; margin:10px 0;">
                <strong><%= c.username %></strong>:
               <!-- Vulnerability: Using <%- without escaping output can cause stored XSS -->
                <%- c.comment %>
            </div>
        <% }) %>
    <% } else { %>
        <p>No comments yet.</p>
    <% } %>

    <h3>Add a Comment</h3>
    <form method="POST" action="/courses/<%= course.id %>/comment">
        <textarea name="comment" rows="4" cols="50" placeholder="Write your comment..."></textarea><br>
        <button type="submit">Post Comment</button>
    </form>

    <p><a href="/courses">Back to Courses</a> | <a href="/payment/checkout/<%= course.id %>">Enroll (Mock Payment)</a></p>
</body>
</html>